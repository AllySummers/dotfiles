#!/usr/bin/env -S deno run --allow-env --allow-run --allow-read --allow-write --allow-net
//MISE description="Sync shell completions for all installed mise tools"
//USAGE flag "--force -f" help="Regenerate all completions regardless of cached version"
//USAGE flag "--verbose -v" help="Print per-tool status"
//USAGE flag "--shell <shell>" help="Limit sync to a specific shell" {
//USAGE   choices "zsh" "bash" "fish"
//USAGE }

import { join } from 'jsr:@std/path@1.1.5';
import { cli } from '../completion-sync/cli.ts';
import type { Shell } from '../completion-sync/shared.ts';

const home = Deno.env.get('HOME')!;
const completionsPath = join(home, '.local', 'share', 'mise-completions');

await cli({
  home,
  taskDir: join(import.meta.dirname!, '../completion-sync'),
  statePath: join(completionsPath, '.state.json'),
  completionsPath,
  force: Deno.env.get('force') === 'true',
  verbose: Deno.env.get('verbose') === 'true',
  shell: Deno.env.get('shell') as Shell,
});
