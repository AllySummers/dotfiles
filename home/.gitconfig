[user]
	name = Ally Summers
	email = git@ay.ms
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[merge]
	renameLimit = 999999
	conflictStyle = zdiff3
[gpg]
	format = ssh
[oh-my-zsh]
	hide-dirty = 1
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
[diff]
	colorMoved = default
# Per-machine signing key, gpgsign, and credential helpers. Create
# ~/.gitconfig.local on each machine; included last so it overrides.
[include]
	path = ~/.gitconfig.local
[credential "https://github.com"]
	helper = 
	helper = !~/.local/share/mise/shims/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !~/.local/share/mise/shims/gh auth git-credential
[credential]
	helper = 
	helper = /usr/local/share/gcm-core/git-credential-manager
[credential "https://dev.azure.com"]
	useHttpPath = true
