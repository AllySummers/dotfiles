# Installed via 'brew bundle --global' inside the [tasks."bootstrap:gui"] task.
# brew: formulae and brew-cask: casks are listed here rather than in
# [bootstrap.packages] in mise's config.macos.toml because mise's brew-cask:
# backend incorrectly counts Homebrew's .metadata directory as a version,
# causing spurious "multiple Caskroom versions found" warnings on every
# `mise install`. Move entries back to config.macos.toml once that is fixed.

# ── Casks: require binary/pkg/preflight artifacts ─────────────────────────────
# Write, edit, and chat about your code with AI (app + CLI binary symlink)
cask "cursor"
# Command-line agent for Cursor (binary only, no .app bundle)
cask "cursor-cli"
# App to build and share containerised applications and microservices
# (app + many binary symlinks + completions + postflight script)
cask "docker-desktop"
# Web browser (preflight script + app + binary symlink)
cask "firefox"
# Cross-platform Git credential storage for multiple hosting providers (pkg installer)
cask "git-credential-manager"
# Open-source code editor (app + 'code' binary symlink)
cask "visual-studio-code"
# Insiders build of VS Code (app + 'code-insiders' binary symlink)
cask "visual-studio-code@insiders"
# Display management utility (app + binary artifact)
cask "betterdisplay"

# ── Casks: moved from [bootstrap.packages] ────────────────────────────────────
cask "1password@beta"
cask "alt-tab"
cask "bettertouchtool"
cask "chatgpt"
cask "discord"
cask "google-chrome"
cask "google-chrome@canary"
cask "kitty"
cask "lastpass"
cask "linearmouse"
cask "shottr"
cask "spotify"

# ── Formulae: moved from [bootstrap.packages] ─────────────────────────────────
brew "bash"
brew "binutils"
brew "calc"
brew "coreutils"
brew "diffutils"
brew "ed"
brew "findutils"
brew "flex"
brew "gawk"
brew "glow"
brew "gnu-sed"
brew "gnu-tar"
brew "gnu-which"
brew "gnupg"
brew "gpatch"
brew "grep"
brew "gzip"
brew "iperf3"
brew "less"
brew "make"
brew "nano"
brew "screen"
brew "watch"
brew "wdiff"
brew "wget"
brew "zip"
brew "zsh"
