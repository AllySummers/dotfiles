{
  "workbench.activityBar.orientation": "vertical",
  "color-highlight.matchWords": true,
  "typescript.disableAutomaticTypeAcquisition": false,
  "terminal.external.osxExec": "Kitty.app",
  "editor.fontFamily": "'Comic Code', 'Hack Nerd Font Mono', 'Font Awesome', Menlo, Monaco, Consolas, 'Courier New', monospace",
  "editor.fontSize": 12,
  "terminal.integrated.scrollback": 50000,
  "editor.formatOnPaste": false,
  "editor.largeFileOptimizations": false,
  "editor.linkedEditing": true,
  "files.exclude": {
    "**/.gitconfig": false,
    "**/.git": false,
    "**/.git-hooks": false
  },
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.quickSuggestions": {
    "comments": "on",
    "strings": "on",
    "other": "on"
  },
  "search.exclude": {
    ".agents/skills": true,
    ".claude/skills": true,
    ".cursor/skills": true
  },
  "editor.snippetSuggestions": "bottom",
  "emmet.showSuggestionsAsSnippets": true,
  "explorer.autoReveal": false,
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.enabled": false,
  "explorer.fileNesting.expand": false,
  "extensions.ignoreRecommendations": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "gitlens.advanced.fileHistoryFollowsRenames": true,
  "gitlens.codeLens.enabled": true,
  "markdown.preview.doubleClickToSwitchToEditor": false,
  "merge-conflict.autoNavigateNextConflict.enabled": false,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.env.windows": {},
  "terminal.integrated.fontSize": 12,
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always",
  "git.openRepositoryInParentFolders": "never",
  "json.maxItemsComputed": 100000,
  "editorconfig.generateAuto": false,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "yaml.maxItemsComputed": 500000,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": false,
  "javascript.inlayHints.variableTypes.suppressWhenTypeMatchesName": false,
  "editor.accessibilitySupport": "off",
  "debug.console.fontSize": 13,
  "terminal.integrated.stickyScroll.enabled": false,
  "gitlens.showWhatsNewAfterUpgrades": false,
  "gitlens.plusFeatures.enabled": false,
  "security.promptForLocalFileProtocolHandling": false,
  "js/ts.implicitProjectConfig.target": "ESNext",
  "eslint.ignoreUntitled": true,
  "github.copilot.advanced": {
    "enableRemoteAgents": true,
    "useLanguageServer": true,
    "authProvider": "github"
  },
  "deno.maxTsServerMemory": 6144,
  "diffEditor.useInlineViewWhenSpaceIsLimited": false,
  "gitlens.views.scm.grouped.views": {
    "commits": false,
    "branches": false,
    "remotes": false,
    "stashes": false,
    "tags": false,
    "worktrees": false,
    "contributors": false,
    "fileHistory": false,
    "repositories": false,
    "searchAndCompare": false,
    "launchpad": false
  },
  "files.associations": {
    ".gitignore.local": "ignore",
    "*.json5": "jsonc"
  },
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "keep",
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.detectIndentation": false
  },
  "diffEditor.renderSideBySide": true,
  "application.shellEnvironmentResolutionTimeout": 30,
  "typescript.tsserver.maxTsServerMemory": 6144,
  "git.blame.editorDecoration.enabled": true,
  "gitlens.views.remotes.branches.layout": "list",
  "gitlens.views.branches.files.layout": "tree",
  "terminal.integrated.macOptionIsMeta": true,
  "editor.wrappingIndent": "indent",
  "gitlens.views.commits.files.layout": "tree",
  "terminal.integrated.suggest.enabled": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "gitlens.graph.dimMergeCommits": true,
  "github.gitAuthentication": true,
  "workbench.colorTheme": "Default Dark Modern",
  "cursor.composer.shouldAllowCustomModes": true,
  "cursor.composer.shouldAutoScrollToBottom": false,
  "json.schemaDownload.enable": true,
  "redhat.telemetry.enabled": false,
  "githubPullRequests.pullBranch": "never",
  "playwright.reuseBrowser": false,
  "comments.visible": false,
  "window.commandCenter": true,
  "cursor.cpp.enablePartialAccepts": true,
  "peacock.affectSashHover": false,
  "peacock.keepForegroundColor": true,
  "peacock.showColorInStatusBar": false,
  "peacock.affectActivityBar": false,
  "peacock.affectTitleBar": false,
  "playwright.showTrace": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.rebaseEditor.openOnPausedRebase": false,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "chat.tools.terminal.outputLocation": "chat",
  "chat.editing.alwaysSaveWithGeneratedChanges": true,
  "bookmarks.label.suggestion": "suggestWhenSelected",
  "bookmarks.saveBookmarksInProject": true,
  "bookmarks.sideBar.expanded": true,
  "editor.bracketPairColorization.enabled": false,
  "gitlens.showWelcomeOnInstall": false,
  "gitlens.telemetry.enabled": false,
  "html.format.wrapAttributes": "force-aligned",
  "html.format.wrapLineLength": 100,
  "projectManager.sortList": "Name",
  "nginx-conf-hint.format.align": true,
  "nxConsole.enableTelemetry": false,
  "nxConsole.showNodeVersionOnStartup": false,
  "prettier.bracketSameLine": true,
  "prettier.htmlWhitespaceSensitivity": "strict",
  "prettier.printWidth": 100,
  "prettier.resolveGlobalModules": true,
  "prettier.singleQuote": true,
  "prettier.tabWidth": 4,
  "prettier.trailingComma": "all",
  "shebang.associations": [
    {
      "language": "typescriptreact",
      "pattern": "^#!/usr/bin/env(-S )? (deno).*--ext tsx.*$"
    },
    {
      "language": "typescript",
      "pattern": "^#!/usr/bin/env(-S )? (deno).*--ext ts.*$"
    },
    {
      "language": "shellscript",
      "pattern": "^#!/usr/bin/env(-S )? (bash|zsh|sh)$"
    }
  ],
  "shell-syntax.defaultShell": "zsh",
  "shellcheck.ignorePatterns": {
    "**/*.csh": true,
    "**/*.cshrc": true,
    "**/*.fish": true,
    "**/*.login": true,
    "**/*.logout": true,
    "**/*.tcsh": true,
    "**/*.tcshrc": true,
    "**/*.xonshrc": true,
    "**/*.xsh": true,
    "**/*.zlogin": false,
    "**/*.zlogout": false,
    "**/*.zprofile": false,
    "**/*.zsh": false,
    "**/*.zsh-theme": false,
    "**/*.zshenv": false,
    "**/*.zshrc": false,
    "**/zlogin": false,
    "**/zlogout": false,
    "**/zprofile": false,
    "**/zshenv": false,
    "**/zshrc": false
  },
  "telemetry.telemetryLevel": "off",
  "terminal.external.windowsExec": "wt.exe",
  "terminal.integrated.defaultProfile.windows": "Windows PowerShell",
  "terminal.integrated.gpuAcceleration": "on",
  "update.showReleaseNotes": false,
  "window.confirmBeforeClose": "keyboardOnly",
  "terminal.integrated.profiles.windows": {
    "Command Prompt": {
      "args": [],
      "icon": "terminal-cmd",
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe",
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ]
    },
    "Git Bash": {
      "source": "Git Bash"
    },
    "PowerShell": {
      "icon": "terminal-powershell",
      "source": "PowerShell"
    }
  },
  "workbench.experimental.share.enabled": true,
  "mise.binPath": "{{ if eq .chezmoi.os "windows" }}{{ .chezmoi.homeDir | replace "\\" "/" }}/AppData/Local/mise/mise.exe{{ else }}{{ .chezmoi.homeDir }}/.local/bin/mise{{ end }}",
  "claudeCode.selectedModel": "claude-sonnet-4-6",
  "workbench.editor.enablePreview": false,
  "cursor.inlineDiff.enablePerformanceProtection": false,
  "update.mode": "silentlyApplyOnQuit",
  "semanticdiff.diff.contextLines": 1000000,
  "mise.configureExtensionsAutomatically": true,
  "typescript.updateImportsOnFileMove.enabled": "never",
  "cursor.general.disableHttp2": true,
  "window.autoDetectColorScheme": false,
  "git.autorefresh": true,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.hg/store/**": true,
    "**/.next/**": true
  },
  "update.releaseTrack": "dev"
}
